# ============================================================
# ai-news .env.example — 全環境変数のサンプル
# 実際の値を .env にコピーして設定してください
# .env は .gitignore 対象（コミット禁止）
# ============================================================

# ── Gemini API ───────────────────────────────────────────────
GEMINI_API_KEY=your_gemini_api_key_here
MAX_GEMINI_CONCURRENCY=2

# ── VOICEVOX (docker-compose内部URL — docker-compose.ymlで設定済み・変更不要) ──
# VOICEVOX_URL=http://voicevox:50021

# ── Playwright Chrome (docker-compose内部URL — docker-compose.ymlで設定済み・変更不要) ──
# PLAYWRIGHT_CDP_ENDPOINT=ws://playwright-chrome:3000

# ── Navidrome (Subsonic API) ─────────────────────────────────
NAVIDROME_URL=http://192.168.0.23:4533
NAVIDROME_USER=your_navidrome_user
NAVIDROME_PASS=your_navidrome_password

# ── Samba (SMB2 — go-smb2でMP3を書き込み・読み出し) ────────────
SMB_HOST=192.168.0.22
SMB_USER=your_smb_user
SMB_PASS=your_smb_password
SMB_SHARE=Music
SMB_MUSIC_PATH=ai-news

# ── アプリケーション設定 ──────────────────────────────────────
# APP_BASE_URL: broadcasts.file_url に使用するLAN URL
# Cloudflare Tunnel経由のWeb UIアクセス時はHandlerがX-Forwarded-Hostから動的生成するため
# このURLはHA向けのmedia_urlとして固定使用される
APP_BASE_URL=http://192.168.0.13:8181
DB_PATH=/data/news.db
PORT=8181
TZ=Asia/Tokyo
