# ============================================================
# ai-news .env.example — Template for all environment variables
# Copy this file to .env and fill in your actual values.
# .env is listed in .gitignore and must NOT be committed.
# ============================================================

# -- Gemini API ----------------------------------------------
# Get your API key from Google AI Studio (NOT Google Cloud Console):
#   https://aistudio.google.com/apikey
# GCP Console API keys do NOT work — you need an AI Studio key.
GEMINI_API_KEY=your_gemini_api_key_here
MAX_GEMINI_CONCURRENCY=2

# -- VOICEVOX (set via docker-compose.yml, no change needed) -
# VOICEVOX_URL=http://voicevox:50021

# -- Playwright Chrome (set via docker-compose.yml, no change needed) --
# PLAYWRIGHT_CDP_ENDPOINT=ws://playwright-chrome:3000

# -- Navidrome (Subsonic API) --------------------------------
NAVIDROME_URL=http://192.168.0.23:4533
NAVIDROME_USER=your_navidrome_user
NAVIDROME_PASS=your_navidrome_password

# -- Samba (SMB2 via go-smb2, for MP3 read/write) -----------
SMB_HOST=192.168.0.22
SMB_USER=your_smb_user
SMB_PASS=your_smb_password
SMB_SHARE=Music
SMB_MUSIC_PATH=ai-news

# -- Application settings ------------------------------------
# APP_BASE_URL: LAN URL used for broadcasts.file_url (fixed, for HA media_url)
# Web UI via Cloudflare Tunnel uses X-Forwarded-Host header dynamically instead.
APP_BASE_URL=http://192.168.0.13:8181
DB_PATH=/data/news.db
PORT=8181
TZ=Asia/Tokyo

# -- Google Cloud TTS (optional, faster alternative to VOICEVOX) ---------
# Switch TTS engine per-category via Settings > Category > Edit.
# 1. Enable Cloud Text-to-Speech API in GCP Console.
# 2. Create an API key (Application restrictions: None,
#    API restrictions: Cloud Text-to-Speech API only).
# Japanese voices: ja-JP-Neural2-B (female), ja-JP-Neural2-D (male),
#                  ja-JP-Neural2-C (male), ja-JP-Neural2-F (female)
# Free tier: 1,000,000 chars/month. Over-quota: $16/1M chars.
GCLOUD_TTS_KEY=
GCLOUD_TTS_VOICE=ja-JP-Neural2-B
